{
  "name": "obstacle-course",
  "private": true,
  "version": "0.3.3",
  "type": "module",
  "main": "index.js",
  "description": "React Native app (web via react-native-web + Tauri; native via Expo) — a Playwright obstacle course.",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview --port 4173 --strictPort",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "tauri:e2e": "tauri dev --config src-tauri/tauri.e2e.conf.json --features e2e-testing",
    "tauri:e2e:build": "tauri build --config src-tauri/tauri.e2e.conf.json --features e2e-testing",
    "start": "expo start",
    "ios": "expo run:ios",
    "android": "expo run:android",
    "test": "playwright test",
    "test:headed": "playwright test --headed",
    "test:ui": "playwright test --ui",
    "test:report": "playwright show-report"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "1.23.1",
    "expo": "~52.0.0",
    "expo-status-bar": "~2.0.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-native": "^0.76.9",
    "react-native-web": "^0.19.13",
    "react-router-dom": "^6.26.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@srsholmes/tauri-playwright": "^0.4.0",
    "@tauri-apps/cli": "^2.1.0",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "typescript": "^5.6.2",
    "vite": "^5.4.6"
  }
}
